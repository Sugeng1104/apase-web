<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta name="viewport"
      content="width=device-width, initial-scale=1.0">

<title>PTK Panditan 1 - APASE WEB</title>

<link rel="preconnect"
      href="https://fonts.googleapis.com">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{

min-height:100vh;

background:
linear-gradient(
135deg,
#0f172a,
#1e3a8a,
#2563eb
);

padding:30px;

overflow-x:hidden;

color:white;

}

/* BACKGROUND */

.blur1,
.blur2{

position:fixed;

border-radius:50%;

filter:blur(120px);

opacity:.4;

z-index:0;

}

.blur1{

width:350px;
height:350px;

background:#60a5fa;

top:-120px;
left:-120px;

}

.blur2{

width:350px;
height:350px;

background:#2563eb;

bottom:-120px;
right:-120px;

}

/* CONTAINER */

.container{

position:relative;

z-index:2;

max-width:1400px;

margin:auto;

}

/* HEADER */

.header{

background:
rgba(255,255,255,0.12);

backdrop-filter:blur(20px);

border:
1px solid rgba(255,255,255,0.15);

border-radius:35px;

padding:40px 30px;

text-align:center;

margin-bottom:30px;

box-shadow:
0 10px 35px rgba(0,0,0,0.25);

}

.header h1{

font-size:40px;

font-weight:700;

margin-bottom:10px;

}

.header p{

color:#dbeafe;

font-size:16px;

}

/* SEARCH */

.search-box{

margin-bottom:30px;

display:flex;

justify-content:center;

}

.search-box input{

width:100%;

max-width:500px;

padding:16px 20px;

border:none;

outline:none;

border-radius:18px;

background:
rgba(255,255,255,0.15);

backdrop-filter:blur(10px);

color:white;

font-size:16px;

}

.search-box input::placeholder{

color:#dbeafe;

}

/* STAT */

.stat-grid{

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(250px,1fr));

gap:25px;

margin-bottom:30px;

}

.stat-card{

background:
rgba(255,255,255,0.12);

backdrop-filter:blur(20px);

border:
1px solid rgba(255,255,255,0.15);

border-radius:30px;

padding:30px;

text-align:center;

box-shadow:
0 10px 35px rgba(0,0,0,0.2);

}

.stat-card h2{

font-size:40px;

margin-bottom:10px;

}

.stat-card p{

color:#dbeafe;

}

/* CARD GRID */

.card-grid{

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(320px,1fr));

gap:25px;

margin-bottom:40px;

}

.teacher-card{

background:
rgba(255,255,255,0.12);

backdrop-filter:blur(20px);

border:
1px solid rgba(255,255,255,0.15);

border-radius:30px;

padding:25px;

transition:.3s;

box-shadow:
0 10px 35px rgba(0,0,0,0.2);

}

.teacher-card:hover{

transform:translateY(-8px);

background:
rgba(255,255,255,0.18);

}

.teacher-name{

font-size:22px;

font-weight:700;

margin-bottom:10px;

}

.teacher-job{

display:inline-block;

padding:8px 14px;

border-radius:12px;

background:
rgba(255,255,255,0.15);

font-size:13px;

margin-bottom:18px;

}

.teacher-info{

font-size:14px;

line-height:1.8;

color:#e2e8f0;

}

/* TABLE */

.table-container{

background:
rgba(255,255,255,0.12);

backdrop-filter:blur(20px);

border:
1px solid rgba(255,255,255,0.15);

border-radius:35px;

padding:25px;

overflow-x:auto;

box-shadow:
0 10px 35px rgba(0,0,0,0.2);

}

.table-title{

font-size:24px;

font-weight:700;

margin-bottom:20px;

}

table{

width:100%;

border-collapse:collapse;

}

th,
td{

padding:15px;

text-align:left;

border-bottom:
1px solid rgba(255,255,255,0.08);

font-size:14px;

vertical-align:top;

}

th{

background:
rgba(255,255,255,0.1);

color:#dbeafe;

}

/* BUTTON */

.button-area{

margin-top:35px;

text-align:center;

}

.back-btn{

display:inline-block;

padding:14px 28px;

border-radius:16px;

background:white;

color:#1e3a8a;

text-decoration:none;

font-weight:700;

transition:.3s;

box-shadow:
0 10px 25px rgba(0,0,0,0.2);

}

.back-btn:hover{

background:#dbeafe;

transform:translateY(-3px);

}

/* LOADING */

.loading{

text-align:center;

font-size:20px;

padding:40px;

color:#dbeafe;

}

/* RESPONSIVE */

@media(max-width:768px){

body{

padding:15px;

}

.header h1{

font-size:30px;

}

}

</style>

</head>

<body>

<div class="blur1"></div>
<div class="blur2"></div>

<div class="container">

<!-- HEADER -->

<div class="header">

<h1>
DATA PTK PANDITAN 1
</h1>

<p>
Data Pendidik dan Tenaga Kependidikan
</p>

</div>

<!-- SEARCH -->

<div class="search-box">

<input type="text"
       id="searchInput"
       placeholder="Cari nama PTK...">

</div>

<!-- STAT -->

<div class="stat-grid">

<div class="stat-card">

<h2 id="totalPTK">
0
</h2>

<p>Total PTK</p>

</div>

</div>

<!-- LOADING -->

<div class="loading"
     id="loading">

Memuat data PTK...

</div>

<!-- CARD -->

<div class="card-grid"
     id="cardGrid">

</div>

<!-- TABLE -->

<div class="table-container">

<div class="table-title">

Data Lengkap PTK

</div>

<table>

<thead>

<tr>

<th>NO</th>
<th>NAMA</th>
<th>NIP / NRPTT / NRTS</th>
<th>TEMPAT LAHIR</th>
<th>TANGGAL LAHIR</th>
<th>PANGKAT</th>
<th>PENDIDIKAN</th>
<th>TUGAS</th>
<th>MULAI</th>
<th>NUPTK</th>
<th>ALAMAT</th>
<th>STATUS</th>

</tr>

</thead>

<tbody id="tableBody">

</tbody>

</table>

</div>

<!-- BUTTON -->

<div class="button-area">

<a href="dashboard.html"
   class="back-btn">

← Kembali ke Dashboard

</a>

</div>

</div>

<script>

// CSV URL
const CSV_URL =
"https://drive.google.com/uc?export=download&id=1JK2WRt4X3v-AlZ2N5cDzdeY5Bz1rK9QM";

// ELEMENT
const tableBody =
document.getElementById(
"tableBody"
);

const cardGrid =
document.getElementById(
"cardGrid"
);

const totalPTK =
document.getElementById(
"totalPTK"
);

const loading =
document.getElementById(
"loading"
);

const searchInput =
document.getElementById(
"searchInput"
);

let allData = [];

// LOAD CSV
async function loadCSV(){

try{

const response =
await fetch(CSV_URL);

const text =
await response.text();

const rows =
text.split("\n")
.map(row => row.split(","));

allData =
rows.slice(1);

renderData(allData);

loading.style.display =
"none";

}
catch(error){

loading.innerHTML =
"Gagal memuat data";

console.log(error);

}

}

// RENDER
function renderData(data){

tableBody.innerHTML = "";
cardGrid.innerHTML = "";

totalPTK.innerText =
data.length;

data.forEach(row => {

const no = row[0] || "-";
const nama = row[1] || "-";
const nip = row[2] || "-";
const tempat = row[3] || "-";
const tanggal = row[4] || "-";
const pangkat = row[5] || "-";
const pendidikan = row[6] || "-";
const tugas = row[7] || "-";
const mulai = row[8] || "-";
const nuptk = row[9] || "-";
const alamat = row[10] || "-";
const status = row[11] || "-";

// CARD
cardGrid.innerHTML += `

<div class="teacher-card">

<div class="teacher-name">
${nama}
</div>

<div class="teacher-job">
${tugas}
</div>

<div class="teacher-info">

<b>NIP:</b> ${nip}<br>

<b>Pendidikan:</b> ${pendidikan}<br>

<b>Status:</b> ${status}<br>

<b>NUPTK:</b> ${nuptk}

</div>

</div>

`;

// TABLE
tableBody.innerHTML += `

<tr>

<td>${no}</td>
<td>${nama}</td>
<td>${nip}</td>
<td>${tempat}</td>
<td>${tanggal}</td>
<td>${pangkat}</td>
<td>${pendidikan}</td>
<td>${tugas}</td>
<td>${mulai}</td>
<td>${nuptk}</td>
<td>${alamat}</td>
<td>${status}</td>

</tr>

`;

});

}

// SEARCH
searchInput.addEventListener(
"keyup",
function(){

const keyword =
this.value.toLowerCase();

const filtered =
allData.filter(row => {

return String(row[1])
.toLowerCase()
.includes(keyword);

});

renderData(filtered);

}
);

// INIT
loadCSV();

</script>

</body>
</html>
